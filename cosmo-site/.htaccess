# Cosmo site — Apache config (Hostinger runs Apache + PHP).

# Never serve secrets (.env, .env.example) or server-side includes, even if linked.
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>
RedirectMatch 404 ^/includes/
RedirectMatch 404 ^/sql/

# Basic security headers.
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Pretty-ish: serve index.php at the root.
DirectoryIndex index.php

# Cache static assets for a week.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>

# ---- Clean, extensionless URLs ----
<IfModule mod_rewrite.c>
    RewriteEngine On

    # SEO endpoints — generated by PHP so their URLs carry the configured SITE_URL.
    RewriteRule ^robots\.txt$ robots.php [L]
    RewriteRule ^sitemap\.xml$ sitemap.php [L]

    # /path/index.php -> /path/   (hide the index file)
    RewriteCond %{REQUEST_METHOD} GET
    RewriteCond %{THE_REQUEST} \s/+([^?\s]*?)index\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # /page.php -> /page   (hide the extension). GET only, and never /api/ — the
    # JSON endpoints are POSTed by fetch() and must keep their method + body.
    RewriteCond %{REQUEST_METHOD} GET
    RewriteCond %{REQUEST_URI} !^/api/ [NC]
    RewriteCond %{THE_REQUEST} \s/+([^?\s]+)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # Internally serve /page from /page.php when that file exists.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>
