# Cosmo site secrets. COPY THIS to `.env` and fill in. NEVER commit `.env`.
# .htaccess denies serving it; PHP reads it at runtime. No secret lives in any
# .php or .html file — they all read from here via env().

# --- MySQL (Hostinger hPanel -> Databases) ---
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# --- Razorpay (dashboard.razorpay.com -> Settings -> API Keys; start in Test mode) ---
# KEY_ID is public (used by Razorpay Checkout in the browser); KEY_SECRET is server-only.
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR
RAZORPAY_PRESETS=99,199,499

# The real GitHub repo URL, released only after an email is captured. Leave blank
# until the repo is public — the funnel still collects emails and shows
# "you're on the list" until this is set.
REPO_URL=

# Email is ALWAYS required. true = also require a successful tip before the URL.
REQUIRE_PAYMENT_FOR_URL=false

# Admin dashboard password hash.
# Generate: php -r "echo password_hash('your-admin-password', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=

SITE_URL=https://your-domain.com
GEO_ENABLED=true
