{
  "name": "cosmo",
  "version": "0.1.0",
  "description": "Always-on-top desktop companion with animated eyes",
  "author": "Devashish Rana <ranadevashish131@gmail.com>",
  "license": "Apache-2.0",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev": "npm run build && electron .",
    "dev:watch": "concurrently \"tsc -p tsconfig.json --watch\" \"nodemon --watch dist/main/main/index.js --exec electron .\"",
    "build": "node scripts/make-tray-icon.js && tsc -p tsconfig.json && node scripts/bundle-renderer.mjs && cp src/renderer/index.html dist/renderer/renderer/index.html && cp src/main/stt/whisperWorker.mjs dist/main/main/stt/whisperWorker.mjs && cp src/main/memory/embedWorker.mjs dist/main/main/memory/embedWorker.mjs && cp src/main/tts/kokoro/kokoroWorker.mjs dist/main/main/tts/kokoro/kokoroWorker.mjs",
    "dist": "npm run build && electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "licenses:check": "npx --yes license-checker-rseidelsohn --production --failOn 'GPL-1.0;GPL-2.0;GPL-2.0-only;GPL-2.0-or-later;GPL-3.0;GPL-3.0-only;GPL-3.0-or-later;AGPL-1.0;AGPL-3.0;AGPL-3.0-only;AGPL-3.0-or-later;SSPL-1.0'",
    "licenses:generate": "npx --yes generate-license-file --input package.json --output THIRD_PARTY_LICENSES.txt --overwrite"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@ricky0123/vad-web": "^0.0.30",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "electron-store": "^8.2.0",
    "onnxruntime-web": "^1.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "kokoro-js": "^1.2.1",
    "nodemon": "^3.1.4",
    "playwright-core": "^1.60.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.2"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
